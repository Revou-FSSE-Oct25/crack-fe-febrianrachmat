# Base URL NestJS. Lokal: backend :3000, Next dev :3001 jika :3000 sudah dipakai API.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Harus sama dengan JWT_SECRET di service backend Railway.
JWT_SECRET=replace-with-a-strong-secret

# Produksi (contoh):
# NEXT_PUBLIC_API_URL=https://crack-be-febrianrachmat-production.up.railway.app
# Set CORS_ORIGINS di backend = URL frontend Railway Anda.
